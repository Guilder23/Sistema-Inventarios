# Configuración de Django
SECRET_KEY=tu-clave-secreta-super-segura-aqui-cambiar-en-produccion
DEBUG=False
ALLOWED_HOSTS=tu-app.onrender.com,www.tu-dominio.com

# ===== PRODUCCIÓN (RENDER) =====
# Render proporciona DATABASE_URL automáticamente cuando conectas la base de datos
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ===== DESARROLLO LOCAL =====
# Configuración de Base de Datos PostgreSQL (descomentar para desarrollo local)
# DB_NAME=sistema_inventarios
# DB_USER=postgres
# DB_PASSWORD=tu-password
# DB_HOST=localhost
# DB_PORT=5432

# Configuración de Email (opcional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=tu-email@gmail.com
EMAIL_HOST_PASSWORD=tu-password-email

# Configuración de Stock
STOCK_CRITICO=10
STOCK_BAJO=30
